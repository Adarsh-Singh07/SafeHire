{
  "manifest_version": 3,
  "name": "SafeHire AI",
  "version": "1.0",
  "description": "The AI-powered shield for job seekers. Automatically audits job descriptions for scams.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icon.png"
    }
  },
  "icons": {
    "128": "icon.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://*.indeed.com/*",
    "https://*.naukri.com/*",
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.linkedin.com/*",
        "https://*.indeed.com/*",
        "https://*.naukri.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
